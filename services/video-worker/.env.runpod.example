# RunPod Serverless
RUNPOD_API_KEY=your_runpod_api_key_here
RUNPOD_ENDPOINT_ID=your_endpoint_id_here   # Sau khi tạo endpoint trên RunPod dashboard

# Cloudflare R2 Storage
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=learnify-videos
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev  # Public URL của R2 bucket (sau khi enable public access)

# Vercel callback (worker gọi về Vercel để update status)
NEXT_PUBLIC_APP_URL=https://learnify-studio.vercel.app
